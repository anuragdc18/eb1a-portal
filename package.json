{
  "name": "sandbox-app-template",
  "private": true,
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/web",
    "packages/desktop"
  ],
  "scripts": {
    "dev": "npm --workspace packages/web run dev",
    "dev:desktop": "npm --workspace packages/desktop run dev",
    "dev:mobile": "npm --workspace packages/mobile run dev",
    "start": "pm2 delete web-app 2>/dev/null || true; pm2 start ecosystem.config.cjs --update-env",
    "build": "turbo build",
    "build:web": "npm --workspace packages/web run build",
    "lint": "oxlint . --deny-warnings --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --deny-warnings --no-error-on-unmatched-pattern",
    "typecheck": "turbo typecheck",
    "kill:port": "lsof -t -i :${PORT:-4200} | xargs kill -9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.66.0",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "cloudflare": "^5.2.0",
    "pm2": "^7.0.1"
  }
}
